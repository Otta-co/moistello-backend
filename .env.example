# Moistello Backend — Environment Variables
# Copy to .env and customize for your environment
#
# SECURITY: Never commit .env to git. Add it to .gitignore.
# For mainnet secret keys: set them directly on the server, not in files.

# Database
DATABASE_URL=postgres://moistello:moistello_dev@localhost:5432/moistello?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Stellar (testnet defaults)
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Stellar Master Keypair — TESTNET ONLY here.
# For MAINNET production, NEVER store S... in any file.
# Set directly on the server: export MOISTELLO_STELLAR_MASTER_SECRET_KEY="S..."
# Or use AWS Secrets Manager / HashiCorp Vault.
STELLAR_MASTER_PUBLIC_KEY=
STELLAR_MASTER_SECRET_KEY=

# JWT Keys (generated via: cd config/keys && openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem)
JWT_PRIVATE_KEY_PATH=./config/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./config/keys/jwt-public.pem

# Server
SERVER_PORT=1100
ENVIRONMENT=development

# CORS (frontend URL)
ALLOWED_ORIGINS=http://localhost:1110

# Optional: Notification providers
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=
# EMAIL_FROM_ADDRESS=
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=
# SMS_AUTH_TOKEN=
